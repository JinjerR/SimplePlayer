<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tool="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/img_play"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.5"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="@dimen/space_half"
        app:srcCompat="@drawable/icon_play"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/band_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/img_play"
        app:layout_constraintEnd_toEndOf="parent"
        android:maxLines="1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/track_name"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
        tool:text="Jinjer"
        android:layout_marginEnd="@dimen/space_half"
        android:layout_marginStart="@dimen/space_half"
        android:layout_marginBottom="@dimen/space_micro"
        android:layout_marginTop="@dimen/space_half"
        android:textColor="@android:color/white"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/track_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/img_play"
        app:layout_constraintEnd_toEndOf="parent"
        android:maxLines="1"
        app:layout_constraintTop_toBottomOf="@id/band_name"
        app:layout_constraintBottom_toBottomOf="parent"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
        tool:text="Cloud Factory"
        android:layout_marginStart="@dimen/space_half"
        android:layout_marginEnd="@dimen/space_half"
        android:layout_marginBottom="@dimen/space_half"
        android:textColor="@android:color/white"/>

</androidx.constraintlayout.widget.ConstraintLayout>